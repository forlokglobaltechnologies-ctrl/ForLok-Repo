{
  "expo": {
    "name": "FORLOK",
    "slug": "yaaryatra-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "icon": "./assets/forlok_square_orange_icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#071952"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.forlok.mobile"
    },
    "android": {
      "package": "com.forlok.mobile",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/forlok_square_orange_icon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-asset",
      "expo-router"
    ],
    "owner": "n210438",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b4816090-409d-4aff-84a1-3e33efc03375"
      }
    }
  }
}
